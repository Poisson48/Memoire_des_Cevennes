# Mémoire des Cévennes — variables d'environnement
# Copie ce fichier en `.env` et remplis les valeurs.
# Le fichier `.env` est git-ignoré (voir .gitignore).

# Port du serveur Node (défaut 3003).
PORT=3003

# Token admin partagé (X-Admin-Token / cookie admin_token).
# À régénérer pour la prod : `openssl rand -base64 24`.
ADMIN_TOKEN=dev

# Secret de signature des JWT membres.
# OBLIGATOIRE en prod — sinon l'authentification est désactivée.
# Génère-le avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Cookie sécurisé (HTTPS uniquement). Active-le en prod.
COOKIE_SECURE=false

# ─── Sauvegardes ────────────────────────────────────────────────────────
# Passphrase pour chiffrer les archives (AES-256-GCM, scrypt). Si vide,
# les backups restent en clair. À CONSERVER ailleurs que sur le serveur :
# si tu la perds, les anciennes archives chiffrées deviennent illisibles.
# Génère-la avec : openssl rand -base64 32
BACKUP_PASSPHRASE=

# Sauvegarde automatique périodique (en heures). Vide ou 0 = désactivée.
# Ex. 24 = un backup auto par jour.
BACKUP_AUTO_INTERVAL_HOURS=

# Nombre de backups "auto" conservés (les plus anciens sont supprimés).
BACKUP_AUTO_KEEP=14

# Nombre de snapshots "pre-restore" conservés. Ces snapshots sont créés
# automatiquement avant chaque restore/import — au-delà du seuil, les
# plus anciens sont purgés au passage des backups auto.
BACKUP_AUTO_PRE_RESTORE_KEEP=10
