# Mémoire des Cévennes — variables d'environnement
# Copie ce fichier en `.env` et remplis les valeurs.
# Le fichier `.env` est git-ignoré (voir .gitignore).

# Port du serveur Node (défaut 3003).
PORT=3003

# Token admin partagé (X-Admin-Token / cookie admin_token).
# À régénérer pour la prod : `openssl rand -base64 24`.
ADMIN_TOKEN=dev

# Secret de signature des JWT membres.
# OBLIGATOIRE en prod — sinon l'authentification est désactivée.
# Génère-le avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Cookie sécurisé (HTTPS uniquement). Active-le en prod.
COOKIE_SECURE=false
